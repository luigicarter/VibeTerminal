#!/bin/sh
# vibeTerminal vendored launcher for the custom Kimi Code fork
# (claude-code profile set). Shares the standard kimi-code environment
# (~/.kimi-code): login, theme, and session history carry over. Platform-key
# mode (kimi-k3 on Moonshot's Anthropic-compatible endpoint, 1M context)
# activates when a key is available — api.txt next to this package takes
# precedence over KIMI_MODEL_API_KEY; with no key, the providers configured
# in ~/.kimi-code apply (e.g. a Kimi Code subscription via `kimi-custom login`).
ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

if [ -f "$ROOT/api.txt" ]; then
	KIMI_MODEL_API_KEY="$(tr -d '[:space:]' < "$ROOT/api.txt")"
	export KIMI_MODEL_API_KEY
fi

if [ -n "${KIMI_MODEL_API_KEY:-}" ]; then
	: "${KIMI_MODEL_PROVIDER_TYPE:=anthropic}"
	: "${KIMI_MODEL_BASE_URL:=https://api.moonshot.ai/anthropic}"
	: "${KIMI_MODEL_NAME:=kimi-k3}"
	: "${KIMI_MODEL_MAX_CONTEXT_SIZE:=1048576}"
	export KIMI_MODEL_PROVIDER_TYPE KIMI_MODEL_BASE_URL KIMI_MODEL_NAME KIMI_MODEL_MAX_CONTEXT_SIZE
else
	echo "note: no api.txt / KIMI_MODEL_API_KEY - using providers configured in ~/.kimi-code" >&2
fi

NODE_BIN="${VIBE_KIMI_CUSTOM_NODE:-node}"
# Harmless for a real node binary; lets Electron's exe act as node when packaged.
ELECTRON_RUN_AS_NODE=1 exec "$NODE_BIN" "$ROOT/dist/main.mjs" "$@"
