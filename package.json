{
  "name": "vibe-terminal",
  "version": "0.1.67",
  "private": true,
  "description": "A tiled local workspace for running multiple coding agents side by side.",
  "author": "vibeTerminal contributors",
  "homepage": "https://github.com/luigicarter/VibeTerminal#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/luigicarter/VibeTerminal.git"
  },
  "main": "backend/main.cjs",
  "scripts": {
    "dev": "node scripts/app/dev.cjs",
    "dev:frontend": "vite --host 127.0.0.1",
    "dev:renderer": "npm run dev:frontend",
    "build": "tsc --noEmit && vite build",
    "start": "npm run build && electron .",
    "screenshot": "node scripts/qa/screenshot.cjs",
    "screenshot:openfusion": "node scripts/qa/screenshot.cjs --openfusion",
    "smoke:backend:agent-telemetry": "node scripts/backend/agent-telemetry-smoke.cjs",
    "smoke:backend:code-changes": "node scripts/backend/code-changes-smoke.cjs",
    "smoke:backend:build-supervisor": "node scripts/backend/build-supervisor-smoke.cjs",
    "smoke:backend:launch-cwd": "node scripts/backend/launch-cwd-smoke.cjs",
    "smoke:backend:codex-discovery": "node scripts/backend/codex-discovery-smoke.cjs",
    "smoke:backend:claude-discovery": "node scripts/backend/claude-discovery-smoke.cjs",
    "smoke:backend:kimi-discovery": "node scripts/backend/kimi-discovery-smoke.cjs",
    "smoke:backend:kimi-custom-discovery": "node scripts/backend/kimi-custom-discovery-smoke.cjs",
    "smoke:backend:updates": "node scripts/backend/update-smoke.cjs",
    "smoke:backend:fusion-appserver": "node scripts/backend/fusion-appserver-smoke.cjs",
    "smoke:backend:fusion-launch": "node scripts/backend/fusion-launch-smoke.cjs",
    "smoke:backend:fusion-chat-parse": "node scripts/backend/fusion-chat-parse-smoke.cjs",
    "smoke:backend:completion-gate": "node scripts/backend/completion-gate-smoke.cjs",
    "smoke:backend:openfusion-chat-parse": "node scripts/backend/openfusion-chat-parse-smoke.cjs",
    "smoke:backend:openfusion-background-status": "node scripts/backend/openfusion-background-status-smoke.cjs",
    "smoke:backend:openfusion-isolation": "node scripts/backend/openfusion-isolation-smoke.cjs",
    "smoke:backend:openfusion-custom-provider": "node scripts/backend/openfusion-custom-provider-smoke.cjs",
    "smoke:backend:fusion-adapter": "node scripts/backend/fusion-adapter-smoke.cjs",
    "smoke:backend:fusion-watch-build": "node scripts/backend/fusion-watch-build-smoke.cjs",
    "smoke:frontend:attention": "node scripts/frontend/attention-smoke.cjs",
    "smoke:frontend:workspace": "node scripts/frontend/workspace-smoke.cjs",
    "smoke:frontend:session-launch": "node scripts/frontend/session-launch-smoke.cjs",
    "smoke:frontend:fusion-settings": "node scripts/frontend/fusion-settings-smoke.cjs",
    "smoke:frontend:fusion-delegation-race": "node scripts/frontend/fusion-delegation-race-repro.cjs",
    "smoke:frontend:fusion-interrupt-dedupe": "node scripts/frontend/fusion-interrupt-dedupe-repro.cjs",
    "smoke:frontend:cwd-conflicts": "node scripts/frontend/cwd-conflicts-smoke.cjs",
    "smoke:frontend:tiled-resize": "node scripts/frontend/tiled-board-resize-smoke.cjs",
    "smoke:codex-discovery": "npm run smoke:backend:codex-discovery",
    "typecheck": "tsc --noEmit",
    "gen:codex-bindings": "node scripts/dev/gen-codex-bindings.cjs",
    "prepare:codex-bin": "node scripts/dev/prepare-codex-bin.cjs",
    "prepare:codex-bin:required": "node scripts/dev/prepare-codex-bin.cjs --required",
    "smoke:backend:fusion-appserver:embedded": "node scripts/backend/fusion-appserver-smoke.cjs --require-embedded",
    "pack:win": "npm run prepare:codex-bin:required && npm run build && electron-builder --win --dir",
    "dist:win": "npm run prepare:codex-bin:required && npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.vibeterminal.app",
    "productName": "vibeTerminal",
    "artifactName": "vibeTerminal-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "backend/**/*.cjs",
      "node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "vendor/codex-bin",
        "to": "codex-bin"
      },
      {
        "from": "vendor/kimi-custom",
        "to": "kimi-custom"
      }
    ],
    "files": [
      "backend/**",
      "dist/**",
      "frontend/assets/**",
      "node_modules/**",
      "package.json",
      "preload/**",
      "!**/.tmp/**",
      "!**/artifacts/**",
      "!**/docs/**",
      "!**/scripts/**",
      "!**/vendor/**",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "frontend/assets/vibeterminal-logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "vibeTerminal",
      "uninstallDisplayName": "vibeTerminal"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "luigicarter",
        "repo": "VibeTerminal",
        "releaseType": "release"
      }
    ]
  }
}
